include ~/.config/kitty/tokyo_dark.conf
# font_family      JetBrainsMono Nerd Font
# bold_font        auto
# italic_font 	auto
# bold_italic_font auto

font_size  13
adjust_line_height 5
window_padding_width 10 10 10 10  
#tab_bar_edge bottom
#tab_bar_style powerline
#tab_bar_margin_width 0.0
#tab_bar_margin_height 0.0 0.0
#tab_bar_align left
#tab_bar_min_tabs 1

window_decorations normal
hide_window_decorations yes




# BEGIN_KITTY_FONTS
font_family      family="0xProto Nerd Font Mono"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS